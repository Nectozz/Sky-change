-- 🎯 Функция изменения FOV
local function changeFov(value)
    local fov = tonumber(value)
    
    if not fov then
        StatusLabel.Text = "❌ Введите число!"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        task.wait(2)
        StatusLabel.Text = "Готов к работе"
        StatusLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
        return
    end
    
    -- Ограничиваем значения
    fov = math.clamp(fov, 70, 120)
    
    -- Пробуем изменить FOV камеры
    local camera = workspace.CurrentCamera
    if camera then
        camera.FieldOfView = fov
        StatusLabel.Text = "✅ FOV установлен: " .. fov
        StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        
        -- Анимация кнопки
        TweenService:Create(FovButton, TweenInfo.new(0.3), {
            BackgroundColor3 = Color3.fromRGB(100, 255, 100)
        }):Play()
        
        task.wait(1)
        TweenService:Create(FovButton, TweenInfo.new(0.3), {
            BackgroundColor3 = GUI_SETTINGS.AccentColor
        }):Play()
        
        task.wait(1)
        StatusLabel.Text = "Готов к работе"
        StatusLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
    else
        StatusLabel.Text = "❌ Камера не найдена"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        task.wait(2)
        StatusLabel.Text = "Готов к работе"
        StatusLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
    end
end

-- 🌫️ Функция Gray Sky
local function applyGraySky()
    StatusLabel.Text = "🔄 Применяем Gray Sky..."
    StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
    
    -- Анимация кнопки
    TweenService:Create(GraySkyButton, TweenInfo.new(0.3), {
        BackgroundColor3 = Color3.fromRGB(200, 200, 200)
    }):Play()
    
    -- Применяем серое небо
    local sky = Lighting:FindFirstChild("Sky") or Instance.new("Sky")
    
    -- Серые текстуры для неба
    sky.SkyboxBk = "rbxassetid://2350402582"  -- Задняя
    sky.SkyboxDn = "rbxassetid://2350402582"  -- Нижняя
    sky.SkyboxFt = "rbxassetid://2350402582"  -- Передняя
    sky.SkyboxLf = "rbxassetid://2350402582"  -- Левая
    sky.SkyboxRt = "rbxassetid://2350402582"  -- Правая
    sky.SkyboxUp = "rbxassetid://2350402582"  -- Верхняя
    
    -- Настройки освещения
    Lighting.FogColor = Color3.fromRGB(150, 150, 150)  -- Серый туман
    Lighting.FogEnd = 50000  -- Дальность тумана
    Lighting.Brightness = 1  -- Яркость
    Lighting.OutdoorAmbient = Color3.fromRGB(150, 150, 150)  -- Серый окружающий свет
    Lighting.TimeOfDay = "17:00:00"  -- Вечернее время
    
    -- Удаляем старые небеса если есть
    if Lighting:FindFirstChild("sky") then
        Lighting.sky:Destroy()
    end
    
    sky.Parent = Lighting
    
    -- Плавное изменение цвета фона
    for i = 0, 1, 0.05 do
        Lighting.Ambient = Color3.fromRGB(
            math.floor(150 * i),
            math.floor(150 * i),
            math.floor(150 * i)
        )
        task.wait(0.03)
    end
    
    StatusLabel.Text = "✅ Gray Sky активирован"
    StatusLabel.TextColor3 = Color3.fromRGB(200, 200, 255)
    
    task.wait(1)
    TweenService:Create(GraySkyButton, TweenInfo.new(0.3), {
        BackgroundColor3 = Color3.fromRGB(100, 100, 120)
    }):Play()
    
    task.wait(1)
    StatusLabel.Text = "Готов к работе"
    StatusLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
end

-- 🌈 Функция Normal Sky
local function applyNormalSky()
    StatusLabel.Text = "🔄 Возвращаем нормальное небо..."
    StatusLabel.TextColor3 = Color3.fromRGB(100, 200, 255)
    
    -- Анимация кнопки
    TweenService:Create(NormalSkyButton, TweenInfo.new(0.3), {
        BackgroundColor3 = Color3.fromRGB(150, 210, 255)
    }):Play()
    
    -- Возвращаем нормальные настройки
    if Lighting:FindFirstChild("Sky") then
        local sky = Lighting.Sky
        
        -- Возвращаем стандартные текстуры
        sky.SkyboxBk = "rbxasset://textures/sky/sky512_bk.tex"
        sky.SkyboxDn = "rbxasset://textures/sky/sky512_dn.tex"
        sky.SkyboxFt = "rbxasset://textures/sky/sky512_ft.tex"
        sky.SkyboxLf = "rbxasset://textures/sky/sky512_lf.tex"
        sky.SkyboxRt = "rbxasset://textures/sky/sky512_rt.tex"
        sky.SkyboxUp = "rbxasset://textures/sky/sky512_up.tex"
    end
    
    -- Возвращаем нормальные настройки освещения
    Lighting.FogColor = Color3.fromRGB(191, 191, 191)
    Lighting.FogEnd = 100000
    Lighting.Brightness = 1
    Lighting.OutdoorAmbient = Color3.fromRGB(128, 128, 128)
    Lighting.TimeOfDay = "14:00:00"
    
    -- Плавное возвращение цвета
    for i = 1, 0, -0.05 do
        Lighting.Ambient = Color3.fromRGB(
            math.floor(150 * i + 50),
            math.floor(150 * i + 50),
            math.floor(150 * i + 50)
        )
        task.wait(0.03)
    end
    
    StatusLabel.Text = "✅ Нормальное небо восстановлено"
    StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 200)
    
    task.wait(1)
    TweenService:Create(NormalSkyButton, TweenInfo.new(0.3), {
        BackgroundColor3 = Color3.fromRGB(80, 160, 255)
    }):Play()
    
    task.wait(1)
    StatusLabel.Text = "Готов к работе"
    StatusLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
end

